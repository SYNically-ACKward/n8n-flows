        "jsCode": "const log = $json.stdout || '';\nconst match = log.match(/===EXIT_CODE:(-?\\d+)===/);\nconst exitCode = match ? parseInt(match[1], 10) : -1;\n\nreturn {\n  json: {\n    code: exitCode,\n    stdout: log || '(no log found — update may not have started, or host may have restarted mid-run)',\n    stderr: '',\n    hostLabel: 'Docker Host (n8n)',\n    hasDocker: true,\n  },\n};"
      }
    }
