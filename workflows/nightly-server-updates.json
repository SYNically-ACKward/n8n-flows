    {
      "id": "d6945bae-acee-4a89-8f0b-b4f14277d728",
      "name": "Tag Ghost",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        240
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "return {\n  json: {\n    ...$json,\n    hostLabel: 'Ghost (Ubuntu)',\n    hasDocker: false,\n  },\n};"
      }
    },
    {
      "parameters": {
        "jsCode": "const stdout = $json.stdout || '';\nconst stderr = $json.stderr || '';\nconst exitCode = $json.code;\nconst hasDocker = $json.hasDocker;\nconst failed = exitCode != 0 || !!stderr;\n\nconst stages = [\n  { label: 'Refresh package lists (apt update)', test: s => s.includes('---UPDATE DONE---') },\n  { label: 'Upgrade installed packages (apt upgrade)', test: s => /\\d+ upgraded, \\d+ newly installed/.test(s) },\n];\nif (hasDocker) {\n  stages.push({ label: 'Docker cleanup (containers, networks, dangling images, build cache)', test: () => !failed });\n}\n\nlet reachedIndex = -1;\nfor (let i = 0; i < stages.length; i++) {\n  if (stages[i].test(stdout)) reachedIndex = i;\n}\n\nconst checklist = stages.map((stage, i) => {\n  if (i <= reachedIndex) return `✅ ${stage.label}`;\n  if (i === reachedIndex + 1 && failed) return `❌ ${stage.label}`;\n  return `⏭️ ${stage.label} (not reached)`;\n}).join('\\n');\n\nreturn {\n  json: {\n    ...$json,\n    status: failed ? 'failure' : 'success',\n    summary: failed\n      ? `${checklist}\\n\\nError detail:\\n${stderr || '(no stderr captured — check exit code ' + exitCode + ')'}`\n      : checklist,\n  },\n};",
        "mode": "runOnceForEachItem"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        40
      ],
      "id": "0bd8e666-e371-4667-8e59-94ef70e06b1c",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "bc0dbe7d-106b-474d-89f6-32e341201548",
              "leftValue": "={{ $json.status }}",
              "rightValue": "success",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
