{
  "name": "Update Ghost Ubuntu",
  "nodes": [
    {
      "parameters": {
        "authentication": "privateKey",
        "command": "apt update 2>&1 && echo \"---UPDATE DONE---\" && apt upgrade -y 2>&1"
      },
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [
        512,
        64
      ],
      "id": "ce52f941-7136-438b-bf51-731f04e0beec",
